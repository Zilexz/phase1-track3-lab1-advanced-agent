# Sao chép file này thành .env rồi điền API key (file .env đã được .gitignore).
#
# Chế độ chạy: "mock" (mặc định, không cần key) hoặc "llm" (gọi LLM thật).
LAB_MODE=llm

# --- FPT AI Marketplace (OpenAI-compatible) ---
LLM_API_KEY=YOUR_FPT_API_KEY_HERE
LLM_BASE_URL=https://mkp-api.fptcloud.com/v1
LLM_MODEL=GLM-4.7
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3
